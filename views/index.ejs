<!DOCTYPE html>
<html lang="en" class="html">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>homepage</title>
</head>
<body >  
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
  <link rel="stylesheet" href="main.css">

  
<div>
<form id="weatherForm" class="guide-container" method="get">
    <div class="c">
      <h1 style="text-align: center; font-family: 'Montserrat Alternates', sans-serif;" >Weather</h1>
      <input type="search" name="city" placeholder="Search City/State..." id="search_bar" aria-label="Search">
    </div>

  <div class="btn-group" >
  <button type="button" class="btn  dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
    Units
  </button>
  <ul class="dropdown-menu" id="unitSelector">
    <li><a id="unit" class="dropdown-item" data-value="standard">kelvin(K)</a></li>
    <li><a id="unit" class="dropdown-item" data-value="metric">Celsius(°C)</a></li>
    <li><a id="unit" class="dropdown-item" data-value="imperial">Fahrenheit (°F)</a></li>
  </ul>
</div>
  <input type="hidden" name="units" id="unitInput" value="standard">

  <button type="button"  id="response" class="btn " onclick="submitForm('weather')">Weather</button>
  <button type="button" id="response" class="btn " onclick="submitForm('forecast')">Forecast</button>
  <button type="button" id="response" class="btn " onclick="submitForm('air_pollution')">Air Pollution</button>
</form>



<!--WEATHER-->
<% if (type === "weather" && content && content.main) { %>
  <div class="weather">
    <div class="weather-card-inner">
      <h2><%= content.name %>, <%= content.sys.country %></h2>
      <div class="temp-display"><%= content.main.temp %>°</div>
      
      <div class="weather-details">
        <p><strong>Feels Like:</strong> <%= content.main.feels_like %>°</p>
        <p><strong>Weather:</strong> <%= content.weather[0].main %> - <%= content.weather[0].description %></p>
        <hr>
        <div class="stats-grid">
          <p><strong>Humidity:</strong> <%= content.main.humidity %>%</p>
          <p><strong>Pressure:</strong> <%= content.main.pressure %> hPa</p>
          <p><strong>Wind:</strong> <%= content.wind.speed %> m/s</p>
          <p><strong>Clouds:</strong> <%= content.clouds.all %>%</p>
        </div>
      </div>
    </div>
  </div>
<% } %>
<!--FORECAST-->
<% if (type === "forecast" && content && content.list) { %>
  <div class="forecast container">
    <h2 class="mb-4">5-Day Forecast for <%= content.city.name %></h2>
    
    <div class="row g-4 justify-content-center"> 
      <% 
        // Filter the 40 items down to just 5 (one for each day at 12:00)
        const dailyForecast = content.list.filter(item => item.dt_txt.includes("12:00:00"));
        
        dailyForecast.forEach((item) => { 
          // Format the date to be more readable
          const date = new Date(item.dt_txt).toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' });
      %>
        <div class="col-12 col-md-6 col-lg-2.4" style="flex: 0 0 auto; width: 20%;"> <div class="forecast-card-inner">
            <p class="date-text"><strong><%= date %></strong></p>
            <div class="temp-val"><%= Math.round(item.main.temp) %>°</div>
            <p class="weather-desc text-capitalize"><%= item.weather[0].description %></p>
            <hr>
            <div class="small-stats">
              <p>💧 <%= item.main.humidity %>%</p>
              <p>💨 <%= item.wind.speed %>m/s</p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>


<% if (type === "air_pollution" && content && content.list) { %>
  <div class="air-quality-container">
    <div class="air-card-inner">
      <h2 style="text-align: center;" >Air quality<h2>
      <% const data = content.list[0]; %>
      
      <div class="aqi-badge aqi-<%= data.main.aqi %>">
        <span class="aqi-number"><%= data.main.aqi %></span>
        <p class="aqi-text"><%= ['Good (0-50)', 'Fair (51-100)', 'Moderate (101–150)', 'Poor (151–200)', 'Very Poor (201+)'][data.main.aqi - 1] %></p>
      </div>

      <hr>

      <div class="pollutant-grid">
        <div class="pollutant"><strong>CO</strong> <span><%= data.components.co %></span></div>
        <div class="pollutant"><strong>NO₂</strong> <span><%= data.components.no2 %></span></div>
        <div class="pollutant"><strong>O₃</strong> <span><%= data.components.o3 %></span></div>
        <div class="pollutant"><strong>SO₂</strong> <span><%= data.components.so2 %></span></div>
        <div class="pollutant"><strong>PM2.5</strong> <span><%= data.components.pm2_5 %></span></div>
        <div class="pollutant"><strong>PM10</strong> <span><%= data.components.pm10 %></span></div>
      </div>
    </div>
  </div>
<% } %>

<script>
  document.addEventListener("DOMContentLoaded", () => {
let selectedUnit = "standard"; // default unit

  document.querySelectorAll('#unitSelector .dropdown-item').forEach(item => {
    item.addEventListener('click', function () {
      selectedUnit = this.getAttribute('data-value');
      console.log("Selected unit:", selectedUnit);

      //updates the unit that is being selected
      document.getElementById('unitInput').value = selectedUnit;

      // Update button label
      document.querySelector('.dropdown-toggle').textContent = this.textContent;
    });
  });
  });

  function submitForm(type) {
    const form = document.getElementById('weatherForm');
    form.action = `/${type}`;
    form.submit();
  }
 </script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
</body>
</html>